# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/deeray?schema=public"

# Admin Session (generate with: openssl rand -hex 32)
SESSION_SECRET="change-this-to-a-random-64-char-hex-string"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (SMTP — optional, order confirmation will skip if unset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@deeray.com"

# Analytics (optional)
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""
